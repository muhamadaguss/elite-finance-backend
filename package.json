{
    "name": "elite-finance-backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "NODE_ENV=development node --env-file=.env --enable-source-maps ./dist/index.mjs",
        "build": "node ./build.mjs",
        "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "db:push": "drizzle-kit push --config ./drizzle.config.ts",
        "db:push-force": "drizzle-kit push --force --config ./drizzle.config.ts"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "cors": "^2",
        "drizzle-orm": "^0.45.1",
        "express": "^5",
        "multer": "^2.1.1",
        "openai": "^6.27.0",
        "openid-client": "^6.8.2",
        "p-limit": "^7.3.0",
        "p-retry": "^7.1.1",
        "pg": "^8.20.0",
        "pino": "^9",
        "pino-http": "^10",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.3.5",
        "@types/pg": "^8.18.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.7",
        "drizzle-kit": "^0.31.9",
        "drizzle-zod": "^0.8.3",
        "esbuild": "^0.27.3",
        "esbuild-plugin-pino": "^2.3.3",
        "pino-pretty": "^13",
        "thread-stream": "3.1.0",
        "typescript": "~5.9.2"
    }
}